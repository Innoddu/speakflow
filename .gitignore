# ---- 의존성 ----
node_modules/
**/node_modules/

# ---- 환경변수 / 시크릿 ----
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ---- 빌드 / 산출물 ----
dist/
build/
**/dist/
**/build/
.expo/
**/.expo/
web-build/

# ---- 런타임 캐시 (백엔드) ----
speakflow-backend/backend/cache/
speakflow-backend/backend/data/
speakflow-backend/backend/public/audio/
speakflow-backend/backend/uploads/

# ---- 에디터 / OS / 도구 ----
.claude/
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- 네이티브 빌드 ----
